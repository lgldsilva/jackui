# Frontend
web/node_modules/
web/dist/

# Built frontend assets (populated by npm run build)
ui/dist/*
!ui/dist/.gitkeep

# Binary
jackui

# Config e segredos — nunca versionar
config.yaml
.env
*.yaml
!*.example.yaml
!docker-compose.yml

# OS
.DS_Store
*.swp
*.swo

# Go
*.test
coverage.out
*.cov

# IDE / editor metadata
.idea/
.vscode/
*.bak

# AI tooling worktrees / agent transcripts (Claude Code, Gemini, etc.)
.claude/
.gemini/

# Deepwork progress files (session state, not for the repo)
.slim/
!.slim/deepwork/
!.slim/deepwork/**

# Antigravity (Gemini CLI) — symlinks to external user config, não vai pro repo
.antigravitycli/

# Runtime data — SQLite DBs, stream cache, HLS sessions, thumbnails
/data/
data/
# SQLite DBs criados ao rodar o backend dentro do checkout (jamais versionar)
*.db
*.db-shm
*.db-wal
internal/streamer/streams/

# Allow docker-compose variants that aren't secrets (override the *.yaml rule)
!docker-compose.nvidia.yml
!docker-compose.vaapi.yml
!docker-compose.gluetun.yml
# Sonar scanner workspace
.scannerwork/
/.scannerwork/

# Root-level node tooling (not the web/ app)
*.out
node_modules/

# Electron build output
dist-electron/
electron/dist/
electron/version.json
*.icns
*.ico
/server

# ai-jail sandbox config (local AI tooling, not for the repo)
.ai-jail

# Sonar security artifacts & output
sonar-out/
*.pem

