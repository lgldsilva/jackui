# Copy to .env and fill in the values
JACKETT_URL=http://jackett:9117
JACKETT_API_KEY=your_api_key_here

# TMDB enrichment (optional) — posters + clean title on the search cards.
# Create a free account at https://www.themoviedb.org/ and generate a v3 API key
# under Settings → API. Without this key, /api/tmdb/match returns 503 and ResultCard
# keeps showing just the original title (nothing regresses).
# TMDB_API_KEY=

# OMDb (optional) — the REAL IMDb rating on the cards (instead of the TMDB rating).
# Free key (~1000 req/day) at https://www.omdbapi.com/apikey.aspx
# Without this key, the card shows the TMDB rating as a fallback (labelled "TMDB").
# OMDB_API_KEY=

# Watchlist push notifications via ntfy.sh (optional).
# Pick a unique, hard-to-guess topic (e.g. jackui-luiz-AB12cd34) and subscribe to it
# in the ntfy mobile app: https://ntfy.sh/YOUR_TOPIC. The server-side worker polls
# Jackett every 15 min and fires a push for each new torrent matching a watchlist
# created in the UI.
# JACKUI_NTFY_TOPIC=
# JACKUI_NTFY_URL=https://ntfy.sh

# AI title identification (optional) — cleans the release name before TMDB.
# Same keys as SelfAgent/atrium. Auto-enables when at least one is present.
# Paste the real values here in .env (do NOT commit). OLLAMA is keyless (URL only).
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# Ollama — point it at your host. The same endpoint serves local AND cloud models
# (models with a "-cloud" suffix, proxied via the API key already configured in ollama):
# OLLAMA_BASE_URL=http://your-ollama-host:11434

# E-mail (SMTP) — used for password reset, e-mail confirmation and invites.
# Without it, those flows become admin-copyable links (no e-mail is sent).
# Gmail example: host smtp.gmail.com, port 587, user the e-mail, pass an "app password".
# JACKUI_SMTP_HOST=smtp.gmail.com
# JACKUI_SMTP_PORT=587
# JACKUI_SMTP_USER=you@gmail.com
# JACKUI_SMTP_PASS=
# JACKUI_SMTP_FROM=JackUI <you@gmail.com>
# Public app URL — the base for the links in e-mails (reset/confirmation/invite).
# JACKUI_BASE_URL=https://jackui.example.com

# SonarQube — static analysis (make sonar-scan).
# Generate the token at: Your Account → Security → Generate Token
# SONAR_HOST_URL=https://sonar.example.com
# SONAR_TOKEN=squ_...

# ── Deploy (make deploy-*) — remote target and path layout ──────────────────
# The Makefile and docker-compose.yml read these values from here (gitignored), so
# the public repo carries nothing machine-specific. Without them, generic defaults
# apply (context "default", local ./data/*).
# DOCKER_CONTEXT=my-docker-context
# DEPLOY_HOST=user@host
# REMOTE_CONFIG_DIR=/opt/jackui          # where config.yaml is synced on the server
# Host paths for the volume bind mounts. Point these at your storage:
# JACKUI_CONFIG_DIR=/opt/jackui          # config.yaml + state DBs
# JACKUI_CACHE_DIR=/srv/jackui/cache     # streamer piece cache (large disk)
# JACKUI_STORAGE_DIR=/srv/media          # shared library (promote target)
# Optional extra mounts (rclone/NFS); leave blank to fall back to ./data/*:
# JACKUI_MEDIA_MOUNT=/mnt/rclone/media
# JACKUI_SENSITIVE_MOUNT=/mnt/rclone/sensitive
